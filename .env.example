# ResVerity Environmental Configurations Template
# Copy this file to .env.local in root or inside /web folder and fill in values

# Google Gemini API Key for NLP & AI Categorization
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configurations (Optional - falls back to local JSON db if empty)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
